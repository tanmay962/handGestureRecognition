# Gesture Detection v1.0 — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8000
HOST=0.0.0.0

# CORS — comma-separated list of allowed origins (defaults to localhost only)
# Add your deployed frontend URL here for production
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Optional: Google Gemini AI (get free key at aistudio.google.com)
GEMINI_API_KEY=

# Optional: MQTT Broker (default: HiveMQ public broker — use a private broker in production)
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_USER=
MQTT_PASS=
MQTT_TOPIC=gesture-detection/sensor/features

# Admin
ADMIN_PIN=1234
